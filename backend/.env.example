# =============================================================================
# Quick Commerce Backend - Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# =============================================================================
# PROCESS CONTROL
# =============================================================================

# Process role: api | worker | scheduler | all
# - api: HTTP server + WebSocket only (no background jobs)
# - worker: Bull queue processor only (no HTTP server)
# - scheduler: Scheduled job runner only (no HTTP server)
# - all: All components in one process (development fallback only; not allowed in production)
PROCESS_ROLE=all

# Legacy alias (deprecated): prefer PROCESS_ROLE.
# APP_ROLE=all

# Node environment: development | production | test
NODE_ENV=development

# HTTP server port (API role)
PORT=7000

# Health check server port (worker/scheduler roles)
HEALTH_CHECK_PORT=9090

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# MongoDB connection timeout in milliseconds (default: 10000)
# MONGO_CONNECT_TIMEOUT_MS=10000

# Maximum MongoDB connection retries (default: 5)
# MONGO_MAX_RETRIES=5

# =============================================================================
# REDIS
# =============================================================================
# Redis is REQUIRED in production (NODE_ENV=production).
# In development/test, Redis is optional (graceful degradation).

# Redis connection URL (preferred)
# REDIS_URL=redis://127.0.0.1:6379

# Redis host (used if REDIS_URL not set)
# REDIS_HOST=127.0.0.1

# Redis port (default: 6379)
# REDIS_PORT=6379

# Redis password (optional)
# REDIS_PASSWORD=

# Explicitly enable Redis (useful in test environments)
# REDIS_ENABLED=true

# Explicitly disable Redis (NOT allowed in production)
# REDIS_DISABLED=false

# Rate limit for Redis error log messages in milliseconds (default: 60000)
# REDIS_ERROR_LOG_INTERVAL_MS=60000

# =============================================================================
# PUSH NOTIFICATIONS (FCM)
# =============================================================================

# Enable/disable push notifications globally
# PUSH_NOTIFICATIONS_ENABLED=true

# Firebase service account JSON string (required for FCM push)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Optional: required only for Firebase Realtime Database operations
# FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Notification dedup key TTL in seconds (default: 86400 = 24h)
# NOTIFICATION_DEDUP_TTL_SEC=86400

# Queue add timeout to avoid blocking API flows (default: 1500ms)
# NOTIFICATION_QUEUE_ADD_TIMEOUT_MS=1500

# Queue processing concurrency per worker (default: 20)
# NOTIFICATION_QUEUE_CONCURRENCY=20

# Queue retries and backoff (default: 3 retries, exponential from 2000ms)
# NOTIFICATION_QUEUE_ATTEMPTS=3
# NOTIFICATION_QUEUE_BACKOFF_MS=2000

# Worker timeout per FCM send job in milliseconds (default: 30000)
# NOTIFICATION_QUEUE_JOB_TIMEOUT_MS=30000

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT secret for token signing (REQUIRED - use strong random string in production)
# Generate: openssl rand -base64 32
JWT_SECRET=your_secure_random_secret_key_minimum_32_characters_long

# JWT expiry (default: 7d)
JWT_EXPIRES_IN=7d

# Admin secret key for admin operations (REQUIRED in production)
ADMIN_SECRET_KEY=your_admin_secret_key

# =============================================================================
# MEDIA / CLOUDINARY
# =============================================================================

# Cloudinary cloud name (required for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API secret
CLOUDINARY_API_SECRET=your_api_secret

# Stored image format for Cloudinary uploads (default: webp)
# CLOUDINARY_IMAGE_UPLOAD_FORMAT=webp

# Stored image quality transformation for Cloudinary uploads (default: auto:good)
# CLOUDINARY_IMAGE_UPLOAD_QUALITY=auto:good

# Enable signed URL uploads (default: true)
# When true: frontend uploads directly to Cloudinary via signed URL
# When false: backend proxies uploads (legacy mode)
ENABLE_SIGNED_UPLOADS=true

# Storage provider (currently: cloudinary)
STORAGE_PROVIDER=cloudinary

# Maximum file size in bytes (default: 10485760 = 10MB)
# MEDIA_MAX_FILE_SIZE=10485760

# Allowed MIME types, comma-separated
# MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Signed URL expiry in seconds (default: 900 = 15 minutes)
# MEDIA_SIGNED_URL_EXPIRY=900

# =============================================================================
# LOGGING
# =============================================================================

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Optional cache-key version prefix for blue/green cache rollouts
# CACHE_KEY_VERSION=v1

# Log format: json | text (default: json)
# LOG_FORMAT=json

# Enable HTTP request logging (default: true)
ENABLE_REQUEST_LOGGING=true

# =============================================================================
# GRACEFUL SHUTDOWN
# =============================================================================

# Graceful shutdown timeout in milliseconds (default: 15000 = 15 seconds)
# SHUTDOWN_TIMEOUT_MS=15000

# Wait for in-flight requests during shutdown (default: true)
# SHUTDOWN_WAIT_FOR_REQUESTS=true

# =============================================================================
# CHECKOUT / ORDER PLACEMENT
# =============================================================================

# Mongo transaction max commit window in milliseconds for atomic checkout.
# CHECKOUT_TRANSACTION_TIMEOUT_MS=20000

# Return window in minutes after order placement (default: 2)
RETURN_WINDOW_MINUTES=2

# =============================================================================
# SCHEDULED JOBS
# =============================================================================

# Order auto-cancel job interval in milliseconds (default: 10000 = 10 seconds)
# AUTO_CANCEL_INTERVAL_MS=10000

# Payout batch job interval in milliseconds (default: 900000 = 15 minutes)
# PAYOUT_BATCH_INTERVAL_MS=900000

# Enable payout batch job (default: false)
# ENABLE_PAYOUT_BATCH_JOB=false

# Payout batch size per run (default: 25)
# PAYOUT_BATCH_LIMIT=25

# =============================================================================
# BULL QUEUES
# =============================================================================

# Process Bull queues inline in API process (NOT recommended for production)
# When false (default), queues are only processed by worker role
# ENABLE_INLINE_QUEUE_WORKER=false

# Stalled job check interval in milliseconds (default: 30000)
# BULL_STALLED_INTERVAL=30000

# Maximum stalled count before job failure (default: 2)
# BULL_MAX_STALLED_COUNT=2

# =============================================================================
# SERVER / CORS
# =============================================================================

# Frontend URL(s) for CORS — comma-separated for multiple domains
FRONTEND_URL=http://localhost:5173

# Explicit CORS allowed origins (overrides FRONTEND_URL if set)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Trust proxy setting (set to "true" when behind load balancer/reverse proxy)
# TRUST_PROXY=true

# API request body size limits
# API_JSON_LIMIT=1mb
# API_URLENCODED_LIMIT=1mb

# Payment webhook max payload size
# PAYMENT_WEBHOOK_MAX_PAYLOAD=1mb

# =============================================================================
# SMS / OTP
# =============================================================================

# USE_REAL_SMS=true  → Send real OTP via SMS
# USE_REAL_SMS=false → Mock mode; use OTP 1234 (no SMS sent)
USE_REAL_SMS=false

# USE_REAL_EMAIL_OTP=true  -> Send real seller email OTP via nodemailer/SMTP
# USE_REAL_EMAIL_OTP=false -> Mock mode; OTP is logged locally
USE_REAL_EMAIL_OTP=false

# Shared SMS OTP module
USE_MOCK_OTP=true
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=4
OTP_MAX_FAILED_ATTEMPTS=5
OTP_SEND_RATE_LIMIT_WINDOW_MS=900000
OTP_SEND_RATE_LIMIT_MAX=5
OTP_VERIFY_RATE_LIMIT_WINDOW_MS=900000
OTP_VERIFY_RATE_LIMIT_MAX=10
SMS_INDIA_HUB_API_KEY=your_api_key
SMS_INDIA_HUB_SENDER_ID=your_sender_id
SMS_INDIA_HUB_DLT_TEMPLATE_ID=your_template_id
SMS_INDIA_HUB_GWID=2
SMS_INDIA_HUB_TEMPLATE_TEXT=Your OTP is {{OTP}}. Valid for {{MINUTES}} minutes.
SMS_INDIA_HUB_URL=http://cloud.smsindiahub.in/vendorsms/pushsms.aspx
SMS_INDIA_HUB_TIMEOUT_MS=10000

# SMTP mailer configuration for seller email OTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
MAIL_FROM=no-reply@example.com
# MAIL_FROM_NAME=Noyo

# Optional: SMS Provider (when USE_REAL_SMS=true)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
# =============================================================================
# GOOGLE MAPS
# =============================================================================

# Google Maps server-side API key (Directions API)
GOOGLE_MAPS_API_KEY=

# =============================================================================
# DELIVERY
# =============================================================================

# Only broadcast to verified riders (default: true)
# DELIVERY_BROADCAST_REQUIRE_VERIFIED=true

# Max documents scanned if $near returns none (default: 2000)
# DELIVERY_BROADCAST_HAVERSINE_LIMIT=2000

# =============================================================================
# TESTING
# =============================================================================

# Enable network-backed finance E2E suite (disabled by default in local/offline runs)
# RUN_E2E_TESTS=false
